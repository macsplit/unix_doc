graph TD
    subgraph ESTAB["Connection Establishment"]
        CLOSED["CLOSED"] -- "Passive Open" --> LISTEN["LISTEN"]
        CLOSED -- "Active Open" --> SYN_SENT["SYN_SENT"]
        LISTEN -- "Receive SYN" --> SYN_RCVD["SYN_RECEIVED"]
        SYN_SENT -- "Receive SYN" --> SYN_RCVD
        SYN_SENT -- "Receive SYN+ACK" --> ESTABLISHED["ESTABLISHED<br/>(Data Transfer)"]
        SYN_RCVD -- "Receive ACK" --> ESTABLISHED
    end

    subgraph TERM["Connection Termination"]
        ESTABLISHED -- "Close" --> FIN_WAIT_1["FIN_WAIT_1"]
        ESTABLISHED -- "Receive FIN" --> CLOSE_WAIT["CLOSE_WAIT"]

        FIN_WAIT_1 -- "Receive FIN" --> CLOSING["CLOSING"]
        FIN_WAIT_1 -- "Receive ACK" --> FIN_WAIT_2["FIN_WAIT_2"]

        CLOSING -- "Receive ACK" --> TIME_WAIT["TIME_WAIT"]
        FIN_WAIT_2 -- "Receive FIN" --> TIME_WAIT

        CLOSE_WAIT -- "Close" --> LAST_ACK["LAST_ACK"]
        LAST_ACK -- "Receive ACK" --> CLOSED2["CLOSED"]
        TIME_WAIT -- "2MSL Timeout" --> CLOSED2
    end

    subgraph ABORT["Early Close"]
        LISTEN -- "Close" --> CLOSED3["CLOSED"]
        SYN_SENT -- "Close" --> CLOSED3
        SYN_RCVD -- "Close" --> FIN_WAIT_1
    end

    ESTAB --> TERM

    style ESTABLISHED fill:#9f9,stroke:#333,stroke-width:2px
    style CLOSED fill:#f99,stroke:#333,stroke-width:2px
    style CLOSED2 fill:#f99,stroke:#333,stroke-width:2px
    style CLOSED3 fill:#f99,stroke:#333,stroke-width:2px
