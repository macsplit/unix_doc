flowchart TD
    subgraph HASH["Hash Table Organization"]
        direction TB
        HT["nc_hash[NCSIZE]"] --> H0["nc_hash[0]"]
        H0 --> E1["ncache entry"]
        E1 --> E2["ncache entry"]

        HT --> H1["nc_hash[1]"]
        H1 --> E3["ncache entry"]

        HT --> Hn["nc_hash[n]"]
        Hn --> E4["ncache entry"]
    end

    subgraph LRU["LRU List (Circular)"]
        direction TB
        HEAD["nc_lru head"] --> |forw| N1["ncache"]
        N1 --> |forw| N2["ncache"]
        N2 --> |forw| N3["ncache"]
        N3 --> |back| HEAD
    end

    subgraph ENTRY["ncache Entry Fields"]
        direction TB
        F1["hash_next: hash chain link"]
        F2["hash_prev: hash chain link"]
        F3["vp: target vnode"]
        F4["dp: parent directory vnode"]
        F5["namlen: name length"]
        F6["name: component name"]
        F7["cred: credentials at lookup"]
    end

    HASH --> LRU
    LRU --> ENTRY
