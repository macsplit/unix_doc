flowchart TD
    subgraph OPEN["fifo_open()"]
        direction TB
        A[Open FIFO] --> B{FREAD mode?}
        B -->|yes| C[Increment fi_readers]
        B -->|no| B2{FWRITE mode?}
        B2 -->|yes| D[Increment fi_writers]
        C --> E[Return 0]
        D --> E
    end

    subgraph READ["fifo_read()"]
        direction TB
        G[Read from FIFO] --> H{No writers and empty?}
        H -->|yes| I[Return EOF]
        H -->|no| J[Copy data to user buffer]
        J --> K[Update fi_head, fi_size]
        K --> L[Return bytes read]
    end

    subgraph WRITE["fifo_write()"]
        direction TB
        M[Write to FIFO] --> N{No readers?}
        N -->|yes| O[Return EPIPE]
        N -->|no| P[Copy data from user buffer]
        P --> Q[Update fi_tail, fi_size]
        Q --> R[Return bytes written]
    end

    OPEN --> READ --> WRITE
